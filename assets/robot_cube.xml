<mujoco model="robot_cube">
  <compiler angle="degree" coordinate="local"/>
  <option timestep="0.01" gravity="0 0 -9.81"/>


  <worldbody>
    <!-- Suelo -->
    <body name="ground" pos="0 0 0">
      <geom name="floor" type="plane" size="10 10 0.1" rgba="0.9 0.9 0.9 1"/>
    </body>

    <!-- Mesa negra -->
    <body name="table" pos="0 0 0.05">
      <geom name="table_surface" type="box" size="2.5 1.5 0.05"
        rgba="0 0 0 1" mass="5"
        friction="0.001 0.00005 0.00005"/>
    </body>

            <!-- PAREDES INVISIBLES (LÍMITES DEL CAMPO) -->
        <!-- Pared +X -->
    <body name="wall_x_plus" pos="2.55 0 0.0">
      <geom name="wall_x_plus_geom" type="box"
            size="0.05 1.5 0.25"  
            rgba="255 255 255 1"
            contype="1" conaffinity="1"
            friction="1.0 0.01 0.01"/>        <!-- Añadimos un poco de rebote -->
    </body>

    <!-- Pared -X -->
    <body name="wall_x_minus" pos="-2.55 0 0.0">
      <geom name="wall_x_minus_geom" type="box"
            size="0.05 1.5 0.25"  
            rgba="255 255 255 1"
            contype="1" conaffinity="1"
            friction="1.0 0.01 0.01"/>
    </body>

    <!-- Pared +Y -->
    <body name="wall_y_plus" pos="0 1.55 0.0">
      <geom name="wall_y_plus_geom" type="box"
            size="2.5 0.05 0.25"  
            rgba="255 255 255 1"
            contype="1" conaffinity="1"
            friction="1.0 0.01 0.01"/>        <!-- Añadimos un poco de rebote -->
    </body>

    <!-- Pared -Y -->
    <body name="wall_y_minus" pos="0 -1.55 0.0">
      <geom name="wall_y_minus_geom" type="box"
            size="2.5 0.05 0.25"  
            rgba="255 255 255 1"
            contype="1" conaffinity="1"
            friction="1.0 0.01 0.01"/>        <!-- Añadimos un poco de rebote -->
    </body>


    <!-- Cuerpo cúbico del robot 1-->
    <body name="cube_body_1" pos="1 1 0.3">
      <geom name="cube_1" type="box" size="0.13 0.13 0.13" 
            rgba="0.20 0.60 0.90 1" mass="0.5"
            friction="0.003 0.00005 0.00005"/>

      <!-- Juntas para desplazar el cubo -->
      <joint name="move_x_1" type="slide" axis="1 0 0" limited="false" damping="0.02"/>
      <joint name="move_y_1" type="slide" axis="0 1 0" limited="false" damping="0.02"/>

        <!-- Rotación en yaw -->
      <joint name="yaw_1" type="hinge" axis="0 0 1" limited="false" damping="0.01"/>

    </body>

    <!-- Cuerpo cúbico del robot 2-->
    <body name="cube_body_2" pos="1 -1 0.3">
      <geom name="cube_2" type="box" size="0.13 0.13 0.13" 
            rgba="0.20 0.80 0.40 1" mass="0.5"
            friction="0.003 0.00005 0.00005"/>
      
      <!-- Juntas para mover el cubo -->
      <joint name="move_x_2" type="slide" axis="1 0 0" limited="false" damping="0.02"/>
      <joint name="move_y_2" type="slide" axis="0 1 0" limited="false" damping="0.02"/>

      <!-- Rotación en yaw -->
      <joint name="yaw_2" type="hinge" axis="0 0 1" limited="false" damping="0.01"/>

    </body>

        <!-- Cuerpo cúbico del robot 3-->
    <body name="cube_body_3" pos="-1 1 0.3">
      <geom name="cube_3" type="box" size="0.13 0.13 0.13" 
            rgba="0.95 0.55 0.20 1" mass="0.5"
            friction="0.003 0.00005 0.00005"/>

      <!-- Juntas para mover el cubo -->
      <joint name="move_x_3" type="slide" axis="1 0 0" limited="false" damping="0.02"/>
      <joint name="move_y_3" type="slide" axis="0 1 0" limited="false" damping="0.02"/>

      <!-- Rotación en yaw -->
      <joint name="yaw_3" type="hinge" axis="0 0 1" limited="false" damping="0.01"/>
    </body>

        <!-- Cuerpo cúbico del robot 4-->
    <body name="cube_body_4" pos="-1 -1 0.3">
      <geom name="cube_4" type="box" size="0.13 0.13 0.13" 
            rgba="0.65 0.35 0.85 1" mass="0.5"
            friction="0.003 0.00005 0.00005"/>
      
      <!-- Juntas para mover el cubo -->
      <joint name="move_x_4" type="slide" axis="1 0 0" limited="false" damping="0.02"/>
      <joint name="move_y_4" type="slide" axis="0 1 0" limited="false" damping="0.02"/>

      <!-- Rotación en yaw -->
      <joint name="yaw_4" type="hinge" axis="0 0 1" limited="false" damping="0.01"/>

    </body>

    <camera name="top_view" pos="0 0 4.0" zaxis="0 0 -1" fovy="60"/>


  </worldbody>

  <!-- Actuadores -->
  <actuator>
    <motor joint="move_x_1" ctrlrange="-0.5 0.5"/>   
    <motor joint="move_y_1" ctrlrange="-0.5 0.5"/>   
    <motor joint="yaw_1"    ctrlrange="-0.2 0.2"/>
    
    <motor joint="move_x_2" ctrlrange="-0.5 0.5"/>
    <motor joint="move_y_2" ctrlrange="-0.5 0.5"/>
    <motor joint="yaw_2"    ctrlrange="-0.2 0.2"/>

    <motor joint="move_x_3" ctrlrange="-0.5 0.5"/>
    <motor joint="move_y_3" ctrlrange="-0.5 0.5"/>
    <motor joint="yaw_3"    ctrlrange="-0.2 0.2"/>
    
    <motor joint="move_x_4" ctrlrange="-0.5 0.5"/>
    <motor joint="move_y_4" ctrlrange="-0.5 0.5"/>
    <motor joint="yaw_4"    ctrlrange="-0.2 0.2"/>
    
  </actuator>
</mujoco>
